# Kid Commute - Environment Variables Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# DATABASE (Required for backend)
# =============================================================================
# PostgreSQL connection URL - automatically provided by Replit
DATABASE_URL=postgresql://user:password@host:port/database

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================
# Session secret for Express sessions - generate a random string
SESSION_SECRET=your-session-secret-here

# =============================================================================
# MOBILE APP CONFIGURATION (Required for Capacitor mobile builds)
# =============================================================================
# The published Replit app URL that mobile apps will connect to
# This must be set BEFORE building the mobile app with "npm run build"
# Example: https://your-app-name.replit.app
VITE_API_URL=https://kid-commute.replit.app

# =============================================================================
# GPS TRACKING - SAMSARA INTEGRATION (Optional)
# =============================================================================
# Samsara API token for GPS tracking integration
SAMSARA_API_TOKEN=your-samsara-api-token

# Samsara webhook secret for validating incoming webhooks
SAMSARA_WEBHOOK_SECRET=your-samsara-webhook-secret

# Generic GPS webhook secret (for non-Samsara GPS providers)
GPS_WEBHOOK_SECRET=your-gps-webhook-secret

# =============================================================================
# PUSH NOTIFICATIONS (Optional - Required for mobile push notifications)
# =============================================================================
# Firebase service account JSON for push notifications
# Get this from Firebase Console > Project Settings > Service Accounts
# Paste the entire JSON as a single line (or use escaped newlines)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# =============================================================================
# PAYROLL INTEGRATION (Optional - Required for BambooHR exports)
# =============================================================================
# BambooHR API token for payroll exports
BAMBOOHR_API_TOKEN=your-bamboohr-api-token

# BambooHR subdomain (company identifier)
BAMBOOHR_SUBDOMAIN=your-company

# =============================================================================
# PAYMENT PORTALS (Optional - Parent billing)
# =============================================================================
# QuickBooks payment portal URL for parents
QUICKBOOKS_PORTAL_URL=https://your-quickbooks-portal-url

# ClassWallet payment portal URL for parents
CLASSWALLET_PORTAL_URL=https://your-classwallet-portal-url

# =============================================================================
# NOTES
# =============================================================================
# 1. For local development, copy this file to .env
# 2. For Replit, set these in the Secrets tab
# 3. For mobile builds, VITE_API_URL must be set before running:
#    npm run build && npx cap sync
# 4. Environment variables prefixed with VITE_ are available in frontend code
